# TokenPanel Environment Configuration
# Copy to .env for local/Docker dev. Bun auto-loads .env.

# --- MongoDB (Docker compose) ---
# When running via `bun run docker:start`, api connects to the `mongo` service
# using MONGO_USER/MONGO_PASS; MONGODB_URI is constructed in compose.yml.
# For non-Docker local dev (bun run dev), point this at a local mongod.
MONGO_USER=tokenpanel
MONGO_PASS=tokenpanel_dev
# Percent-encoded versions for safe mongodb:// URI embedding.
# For URL-safe passwords (e.g. tokenpanel_dev) these are identical to the raw
# values. Only needed if your password contains @, :, /, +, #, etc.
MONGO_USER_URI=tokenpanel
MONGO_PASS_URI=tokenpanel_dev
MONGODB_DB=tokenpanel
MONGO_HOST_PORT=27017

# --- MongoDB (non-Docker, bun run dev) ---
# For migration transactions, mongod must run as a replica set:
#   mongod --replSet rs0 (then run `mongosh --eval 'rs.initiate({_id:"rs0",members:[{_id:0,host:"localhost:27017"}]})')
MONGODB_URI=mongodb://localhost:27017/?directConnection=true

# --- API server ---
PORT=3000
# Secret for JWT signing + symmetric encryption of provider API keys at rest.
# Generate with: bun -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# --- Admin (Vite) ---
# In dev, Vite proxies /admin, /v1, /health to the api (see apps/admin/vite.config.ts).
# In prod, the api serves the admin SPA itself on the same port.
# Set VITE_API_BASE_URL only if admin and api must be on different origins.
ADMIN_HOST_PORT=5173