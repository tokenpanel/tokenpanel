#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" = /* ]] || SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
source "${SCRIPT_DIR}/../lib/config.sh"
source "${SCRIPT_DIR}/../lib/output.sh"
source "${SCRIPT_DIR}/../lib/prompt.sh"
source "${SCRIPT_DIR}/../lib/preflight.sh"
source "${SCRIPT_DIR}/../lib/health.sh"
source "${SCRIPT_DIR}/../lib/lock.sh"

MANAGER_VERSION="$(cat "${SCRIPT_DIR}/../VERSION" 2>/dev/null || echo 'unknown')"

# Compare two semver strings. Returns 0 if $1 >= $2, 1 if $1 < $2, 2 if either
# is not parseable as major.minor.patch (after stripping a leading 'v'). Used
# by the update downgrade check — lexicographic compare mis-orders 1.10.0 <
# 1.9.0. Non-semver inputs (e.g. "unknown", commit hashes) return 2 so the
# caller can skip the check instead of false-refusing.
semver_ge() {
  local a="$1" b="$2"
  a="${a#v}"; a="${a#V}"
  b="${b#v}"; b="${b#V}"
  [[ "$a" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+) ]] || return 2
  local a1="${BASH_REMATCH[1]}" a2="${BASH_REMATCH[2]}" a3="${BASH_REMATCH[3]}"
  [[ "$b" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+) ]] || return 2
  local b1="${BASH_REMATCH[1]}" b2="${BASH_REMATCH[2]}" b3="${BASH_REMATCH[3]}"
  (( a1 > b1 )) && return 0
  (( a1 < b1 )) && return 1
  (( a2 > b2 )) && return 0
  (( a2 < b2 )) && return 1
  (( a3 > b3 )) && return 0
  (( a3 < b3 )) && return 1
  return 0 # equal
}

usage() {
  cat <<EOF
TokenPanel Manager v${MANAGER_VERSION}

Usage: tokenpanel <command> [args]

Lifecycle:
  status       Show container state, version, pending migrations, disk usage
  start        Start all services (preflight + health + post migrations)
  stop         Stop all services
  restart      Restart all services
  rebuild      Rebuild image, recreate containers, apply post migrations

Updates:
  update       Update to latest stable (backup → build → migrate → swap)
  migrate      Run pending migrations without updating image (default: pre)

Config:
  config       Manage operator config (status|render|check|migrate)

Backup:
  backup       Create a mongodump backup
  restore <f>  Restore from a backup archive

Diagnostics:
  logs [-f]    Tail container logs (optionally follow)
  enter [svc]  Exec shell into a container (default: api)
  doctor       Run diagnostics (docker, disk, mongo RS, ports)
  version      Show manager + app versions

Destructive:
  destroy      Stop + remove containers (KEEPS data)
  reset        Stop + remove containers + WIPE ALL data (strong confirm)

Run 'tokenpanel <command> --help' for command-specific options.
EOF
}

cmd_status() {
  preflight_quick 2>/dev/null || true
  step "status" "containers:"
  docker compose -f "$APP_YML" ps --format 'table {{.Name}}\t{{.Status}}\t{{.Ports}}' 2>/dev/null || warn "containers not running"

  local app_version
  app_version="$(cd "$INSTALL_DIR" 2>/dev/null && git describe --tags 2>/dev/null || echo 'unknown')"
  info "app version: $app_version"

  local last_backup
  last_backup="$(find "$BACKUP_DIR" -maxdepth 1 -type f -name '*.gz' 2>/dev/null | sort | tail -1 || true)"
  [ -n "$last_backup" ] && info "last backup: $(basename "$last_backup")" || warn "no backups found"

  local disk_used
  # `|| true` inside the substitution guards against `du` failing when the
  # data dir does not exist yet (fresh host, status run before install). Under
  # set -e + pipefail the pipeline's non-zero exit would otherwise abort the
  # whole status command before the remaining diagnostics print.
  disk_used="$(du -sh "$DATA_DIR" 2>/dev/null | cut -f1 || true)"
  if [ -n "$disk_used" ]; then
    info "data dir: $disk_used at $DATA_DIR"
  fi

  # Pending migrations. migration_status surfaces stderr + the real exit code
  # (no longer suppressed), so invalid migration files are reported loudly.
  # status is read-only: tolerate an offline api with a warning instead of
  # aborting the whole diagnostic.
  source "${SCRIPT_DIR}/../lib/migrate.sh" 2>/dev/null || true
  if declare -F migration_status >/dev/null 2>&1; then
    step "status" "pending migrations:"
    if migration_status; then
      :
    else
      warn "migrations: status unavailable (api not running, or migration files invalid — see errors above)"
    fi
  fi

  # Explicit success: status is a read-only diagnostic command. A missing data
  # dir (uninstalled host) must not leak a non-zero exit code through the empty
  # `disk_used` test above — the command already printed all it could.
  return 0
}

cmd_start() {
  acquire_manager_lock "start" || die "could not acquire manager lock"
  preflight_quick || die "preflight failed"
  step "start" "bringing up containers..."
  docker compose -f "$APP_YML" up -d --remove-orphans
  # `start` may bring up an unknown legacy current image. /health is the
  # frozen contract shared by every supported image.
  wait_for_health api 60 "/health" || die "api did not become healthy"
  # API boot applies pending pre/ migrations. Post/ (destructive) is not run on
  # boot — apply any pending post/ here so first install and plain restarts still
  # reach a fully-migrated schema. Already-applied ids are skipped via
  # `_migrations` tracking (idempotent).
  source "${SCRIPT_DIR}/../lib/migrate.sh"
  step "start" "applying pending post-deploy migrations..."
  run_migrations "post" || die "post-migration failed after start"
  ok "TokenPanel is up"
}

cmd_stop() {
  acquire_manager_lock "stop" || die "could not acquire manager lock"
  step "stop" "stopping containers..."
  docker compose -f "$APP_YML" stop
  ok "stopped"
}

cmd_restart() {
  # Single lock for the whole stop+start cycle (re-entrant acquire inside).
  acquire_manager_lock "restart" || die "could not acquire manager lock"
  cmd_stop
  cmd_start
}

cmd_logs() {
  local follow=""
  local service=""
  if [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]]; then
    follow="-f"
    service="${2:-}"
  else
    service="${1:-}"
  fi
  local args=(logs --tail=100)
  [ -n "$follow" ] && args+=("$follow")
  [ -n "$service" ] && args+=("$service")
  docker compose -f "$APP_YML" "${args[@]}"
}

cmd_enter() {
  local service="${1:-api}"
  docker compose -f "$APP_YML" exec "$service" /bin/sh || \
    die "container '$service' not running. Try 'tokenpanel start' first."
}

cmd_doctor() {
  step "doctor" "running diagnostics..."
  local fail=0

  docker info >/dev/null 2>&1 && ok "docker running" || { err "docker not running"; fail=1; }

  local free_mb
  free_mb="$(df -m /var 2>/dev/null | tail -1 | awk '{print $4}')"
  [ "${free_mb:-0}" -gt 2048 ] && ok "disk: ${free_mb}MB free" || warn "low disk: ${free_mb}MB free"

  docker compose -f "$APP_YML" exec -T mongo mongosh --quiet \
    --eval 'db.hello().isWritablePrimary' 2>/dev/null | grep -q true && \
    ok "mongo: replica set primary" || { err "mongo: not primary or unreachable"; fail=1; }

  port_listening() {
    local port="$1"
    if command -v ss >/dev/null 2>&1; then
      ss -H -tln 2>/dev/null | awk '{print $4}' | grep -Eq ":${port}$"
      return $?
    fi
    if command -v netstat >/dev/null 2>&1; then
      netstat -tln 2>/dev/null | awk '{print $4}' | grep -Eq ":${port}$"
      return $?
    fi
    return 2
  }

  compose_owns_port() {
    local port="$1"
    docker compose -f "$APP_YML" ps --format '{{.Ports}}' 2>/dev/null | grep -q ":${port}->"
  }

  check_port() {
    local port="$1"
    local expected="${2:-optional}"
    local rc=0

    port_listening "$port" || rc=$?
    if [ "$rc" -eq 0 ]; then
      if compose_owns_port "$port"; then
        ok "port ${port}: bound by tokenpanel"
      elif [ "$expected" = "expected" ]; then
        err "port ${port}: in use outside tokenpanel"
        fail=1
      else
        warn "port ${port}: in use outside tokenpanel"
      fi
      return 0
    fi

    if [ "$rc" -eq 2 ]; then
      warn "port ${port}: cannot inspect listeners (ss/netstat unavailable)"
    elif [ "$expected" = "expected" ]; then
      err "port ${port}: not listening"
      fail=1
    fi
  }

  local expected_ports=()
  if [ "${USE_CADDY:-y}" = "y" ]; then
    expected_ports=(80 443)
  else
    expected_ports=("${API_PORT:-3000}")
  fi

  local port expected
  for port in "${expected_ports[@]}"; do
    check_port "$port" expected
  done

  for port in 80 443 3000; do
    expected=0
    for expected_port in "${expected_ports[@]}"; do
      [ "$port" = "$expected_port" ] && { expected=1; break; }
    done
    [ "$expected" -eq 0 ] && check_port "$port" optional
  done

  [ "$fail" -eq 0 ] && ok "all checks passed" || { err "issues found"; exit 1; }
}

cmd_version() {
  echo "TokenPanel Manager v${MANAGER_VERSION}"
  local app_version commit
  app_version="$(cd "$INSTALL_DIR" 2>/dev/null && git describe --tags 2>/dev/null || echo 'unknown')"
  commit="$(cd "$INSTALL_DIR" 2>/dev/null && git rev-parse --short HEAD 2>/dev/null || echo 'unknown')"
  echo "App: ${app_version}"
  echo "Commit: ${commit}"
}

cmd_rebuild() {
  source "${SCRIPT_DIR}/../lib/build.sh"

  acquire_manager_lock "rebuild" || die "could not acquire manager lock"
  preflight_quick || die "preflight failed"
  step "rebuild" "building current checkout image..."
  CURRENT_IMAGE_ID="$(docker compose -f "$APP_YML" images api --format '{{.ID}}' 2>/dev/null | head -1)"
  build_current_checkout_image || die "build failed — old container still available"
  promote_new_image_current || die "could not promote rebuilt image"
  if [ -n "$CURRENT_IMAGE_ID" ]; then
    docker tag "$CURRENT_IMAGE_ID" tokenpanel/app:previous 2>/dev/null || true
  fi

  step "rebuild" "force-recreating containers (keeping data)..."
  docker compose -f "$APP_YML" up -d --force-recreate --remove-orphans
  wait_for_health api 60 || die "api did not become healthy"
  # Same post-deploy step as cmd_start: API boot only runs pre/. Rebuild can
  # ship new post/ files with the new image; apply them now so the live schema
  # matches the rebuilt code. Already-applied ids are skipped (idempotent).
  source "${SCRIPT_DIR}/../lib/migrate.sh"
  step "rebuild" "applying pending post-deploy migrations..."
  run_migrations "post" || die "post-migration failed after rebuild"
  ok "rebuilt"
}

cmd_destroy() {
  step "destroy" "stopping + removing containers (keeping data)..."
  echo
  warn "This stops and removes containers. Your DATA IS PRESERVED."
  warn "Use this when you want to rebuild containers without losing the database."
  echo
  tp_read_required confirm "Proceed? [y/N] " || exit 1
  [[ "$confirm" =~ ^[Yy] ]] || { info "aborted"; exit 0; }
  acquire_manager_lock "destroy" || die "could not acquire manager lock"
  docker compose -f "$APP_YML" down --remove-orphans
  ok "containers removed. Data preserved at $DATA_DIR"
  info "to restart: tokenpanel start"
}

cmd_reset() {
  source "${SCRIPT_DIR}/../lib/config.sh"
  echo -e "${RED}${BOLD}⚠  TOKENPANEL RESET  ⚠${NC}"
  echo
  echo "This will PERMANENTLY DESTROY:"
  echo "  • All MongoDB data (organizations, users, customers, models, usage, billing)"
  echo "  • All backups (mongodump archives)"
  echo "  • All Caddy certificates (Let's Encrypt)"
  echo "  • All container state"
  echo
  echo "This will PRESERVE:"
  echo "  • Manager code (/opt/tokenpanel)"
  echo "  • Configuration (/etc/tokenpanel)"
  echo
  echo -e "${RED}This action is IRREVERSIBLE. No recovery is possible after reset.${NC}"
  echo

  local domain="${DOMAIN:-}"
  if [ -z "$domain" ]; then
    err "DOMAIN not set in config — cannot confirm"
    exit 1
  fi
  echo "To confirm, type your domain name exactly: ${domain}"
  tp_read_required confirm "> " || exit 1
  [ "$confirm" = "$domain" ] || { err "domain mismatch — aborting"; exit 1; }

  echo
  tp_read_required confirm2 "Type RESET in capital letters to proceed: " || exit 1
  [ "$confirm2" = "RESET" ] || { err "did not type RESET — aborting"; exit 1; }

  echo
  warn "resetting in 5 seconds... (Ctrl+C to cancel)"
  sleep 5

  # Lock after confirm so interactive typing does not block peers, but before
  # any destructive work. Lock file lives under CONFIG_DIR (survives DATA wipe).
  acquire_manager_lock "reset" || die "could not acquire manager lock"

  step "reset" "stopping containers..."
  docker compose -f "$APP_YML" down -v --remove-orphans 2>/dev/null || true

  step "reset" "removing data directory..."
  if ! tp_safe_destructive_path "$DATA_DIR"; then
    die "refusing to wipe unsafe data path: '$DATA_DIR' (must be under /opt, /var, /etc, /srv, or /usr/local — not a bare root). Aborting."
  fi
  rm -rf "${DATA_DIR:?}"
  mkdir -p "$DATA_DIR"/mongo "$DATA_DIR"/backups "$DATA_DIR"/caddy

  step "reset" "disabling systemd service..."
  systemctl stop tokenpanel 2>/dev/null || true
  systemctl disable tokenpanel 2>/dev/null || true

  step "reset" "pruning images..."
  docker image rm tokenpanel/app:current tokenpanel/app:previous 2>/dev/null || true
  docker image prune -f 2>/dev/null || true

  echo
  ok "reset complete — all data destroyed"
  info "to reinstall: tokenpanel-setup"
}

cmd_update() {
  local target_version="${1:-}"

  source "${SCRIPT_DIR}/../lib/backup.sh"
  source "${SCRIPT_DIR}/../lib/build.sh"
  source "${SCRIPT_DIR}/../lib/migrate.sh"
  source "${SCRIPT_DIR}/../lib/rollback.sh"
  source "${SCRIPT_DIR}/../lib/config_render.sh"

  # Hold lock for the full update (backup → build → migrate → swap → post).
  # create_backup re-acquires re-entrantly and will not self-deadlock.
  if [ "${TOKENPANEL_UPDATE_BOOTSTRAPPED:-0}" = "1" ]; then
    adopt_manager_lock "${TOKENPANEL_UPDATE_LOCK_FD:-}" \
      || die "refreshed manager did not inherit update lock"
  else
    acquire_manager_lock "update" || die "could not acquire manager lock"
  fi

  echo -e "${BOLD}TokenPanel Update${NC}"
  echo

  # ── Phase 1: PREFLIGHT ──
  step "1/7" "preflight checks..."
  preflight_full || die "preflight failed — aborting (nothing changed)"

  local current_version
  current_version="${TOKENPANEL_UPDATE_FROM_VERSION:-$(cd "$INSTALL_DIR" 2>/dev/null && git describe --tags 2>/dev/null || echo 'unknown')}"
  if [ -n "$target_version" ]; then
    info "target: $target_version (current: $current_version)"
    if [ "$current_version" != "unknown" ]; then
      local cmp=0
      semver_ge "$target_version" "$current_version" || cmp=$?
      if [ "$cmp" -eq 1 ]; then
        die "refusing downgrade: $current_version → $target_version. Restore from backup instead."
      elif [ "$cmp" -eq 2 ]; then
        warn "cannot compare versions ($current_version / $target_version) — skipping downgrade check"
      fi
    fi
  else
    info "current: $current_version, target: latest stable"
  fi
  ok "preflight passed"

  # The installed manager may be older than the target API. Load the target
  # manager before touching the current container so compatibility fixes in the
  # target release govern backup, migration, swap, and rollback behavior.
  # Parent retains the manager lock while the refreshed child runs.
  if [ "${TOKENPANEL_UPDATE_BOOTSTRAPPED:-0}" != "1" ]; then
    step "bootstrap" "refreshing update manager..."
    checkout_update_target "$target_version" \
      || die "manager refresh failed — aborting (app unchanged)"
    ok "target manager loaded"

    local -a update_args=(update)
    if [ -n "$target_version" ]; then
      update_args+=("$target_version")
    fi

    TOKENPANEL_UPDATE_BOOTSTRAPPED=1 \
    TOKENPANEL_UPDATE_LOCK_FD="$MANAGER_LOCK_FD" \
    TOKENPANEL_UPDATE_FROM_VERSION="$current_version" \
      "$INSTALL_DIR/manager/bin/tokenpanel" "${update_args[@]}"
    return $?
  fi

  # ── Phase 2: BACKUP ──
  step "2/7" "creating backup..."
  local backup_file
  backup_file="$(create_backup "pre-update")" \
    || die "backup failed — aborting (app unchanged; manager refreshed)"
  ok "backup ready: $(basename "$backup_file")"

  # ── Phase 3: BUILD ──
  step "3/7" "building new image..."
  build_update_image || die "build failed — aborting (old container still serving, backup available)"
  ok "new image built and tagged"

  # ── Phase 4: CONFIG RECONCILE ──
  step "4/7" "reconciling configuration with target release..."
  ensure_operator_config "$NEW_IMAGE_TAG" \
    || die "operator config migration failed — old container still serving"
  snapshot_config >/dev/null || die "could not snapshot current config"
  render_config_from_image "$NEW_IMAGE_TAG" "$target_version" \
    || die "config render failed — old container still serving; snapshot available"
  ok "configuration rendered to $GENERATED_DIR"

  # ── Phase 5: PRE-MIGRATE ──
  step "5/7" "running pre-deploy migrations from new image (old container still serving)..."
  run_migrations_image "pre" "$NEW_IMAGE_TAG" || die "pre-migration failed — aborting (old container serving, db rolled back per-txn, backup available)"
  ok "pre-deploy migrations applied (from tokenpanel/app:${NEW_IMAGE_TAG})"

  # Only now may Compose's `current` tag move. A failed pre migration above
  # leaves current pointing at the known-good image for starts/reboots.
  promote_new_image_current || die "could not promote new image — aborting (old container serving)"

  # ── Phase 6: SWAP ──
  step "6/7" "swapping to new container..."
  swap_containers || die "swap failed — see rollback output above"
  ok "new container is live and healthy"

  # ── Phase 7: POST-MIGRATE ──
  step "7/7" "running post-deploy migrations..."
  run_migrations "post" || {
    err "post-migration failed!"
    err "new code is live but some destructive migrations may not have applied."
    err "check 'tokenpanel logs' and 'tokenpanel doctor'."
    err "if needed, restore from backup: tokenpanel restore $backup_file"
    return 1
  }
  ok "post-deploy migrations applied"

  cleanup_old_images

  # Refresh the systemd unit from the template so boot/reboot use
  # `tokenpanel start` (health + post migrations), not raw compose up.
  # Safe to re-run: rewrites unit, daemon-reload, enable. Skip if systemd
  # is unavailable (non-systemd hosts still use the CLI).
  if command -v systemctl >/dev/null 2>&1; then
    source "${SCRIPT_DIR}/../lib/systemd.sh"
    install_systemd_service || warn "could not refresh systemd unit — boot may still use raw compose; re-run tokenpanel-setup or install the unit manually"
  fi

  echo
  ok "══════════════════════════════════════"
  ok "  Update complete: $current_version → ${target_version:-latest}"
  ok "  Backup: $(basename "$backup_file")"
  ok "══════════════════════════════════════"
}

cmd_config() {
  source "${SCRIPT_DIR}/../lib/config_render.sh"
  local sub="${1:-status}"
  [ "$#" -gt 0 ] && shift
  local image_tag="${1:-current}"

  case "$sub" in
    status)
      info "operator config: $OPERATOR_CONFIG"
      [ -f "$OPERATOR_CONFIG" ] && ok "operator config exists" || warn "operator config missing"
      info "active compose: $APP_YML"
      info "active env: $ENV_FILE"
      if [ -d "$GENERATED_DIR" ]; then
        ok "generated config: $GENERATED_DIR"
      else
        warn "no generated config yet (run: tokenpanel config render)"
      fi
      ;;
    render)
      acquire_manager_lock "config-render" || die "could not acquire manager lock"
      ensure_operator_config "$image_tag" || die "operator config migration failed"
      snapshot_config >/dev/null || die "could not snapshot config"
      render_config_from_image "$image_tag" || die "config render failed"
      ok "config rendered"
      ;;
    check)
      check_operator_config "$image_tag" || die "config check failed"
      ;;
    migrate)
      ensure_operator_config "$image_tag" || die "legacy config migration failed"
      ok "operator config present at $OPERATOR_CONFIG"
      ;;
    *)
      err "usage: tokenpanel config [status|render|check|migrate] [image-tag]"
      exit 1
      ;;
  esac
}

case "${1:-}" in
  status)   cmd_status ;;
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  rebuild)  cmd_rebuild ;;
  destroy)  cmd_destroy ;;
  reset)    cmd_reset ;;
  logs)     shift; cmd_logs "$@" ;;
  enter)    shift; cmd_enter "$@" ;;
  doctor)   cmd_doctor ;;
  version)  cmd_version ;;
  config)   shift; cmd_config "$@" ;;
  update)   shift; cmd_update "$@" ;;
  backup)   source "${SCRIPT_DIR}/../lib/backup.sh"; create_backup "manual" ;;
  restore)  source "${SCRIPT_DIR}/../lib/backup.sh"; restore_backup "${2:-}" ;;
  migrate)
    acquire_manager_lock "migrate" || die "could not acquire manager lock"
    source "${SCRIPT_DIR}/../lib/migrate.sh"
    run_migrations "${2:-pre}"
    ;;
  *)        usage ;;
esac
