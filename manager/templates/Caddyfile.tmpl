# Caddy reverse proxy config for TokenPanel.
# Rendered by tokenpanel-setup into /etc/tokenpanel/Caddyfile.
# Auto-HTTPS via Let's Encrypt — zero config.

{
	email ${ADMIN_EMAIL}
}

${DOMAIN} {
	reverse_proxy api:3000 {
		# Client IP for API credential throttles (TRUST_PROXY=true on api).
		# X-Real-IP = TCP peer of Caddy (true client when Caddy is edge;
		# Cloudflare edge when CF is in front — then enable TRUST_CLOUDFLARE
		# and pass CF-Connecting-IP, which reverse_proxy forwards by default).
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		# JWT lives in localStorage — CSP is the primary XSS containment layer.
		Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
	}
}
