# TokenPanel environment configuration.
# Rendered by tokenpanel-setup into /etc/tokenpanel/.env.
# DO NOT COMMIT rendered version — contains secrets.
#
# MONGO_USER / MONGO_PASS are the raw MongoDB root credentials.
# MONGO_USER_URI / MONGO_PASS_URI are percent-encoded versions for safe
# embedding in mongodb:// URIs (a password containing @:/+ etc. would
# otherwise break the connection string).

MONGO_USER=${MONGO_USER}
MONGO_PASS=${MONGO_PASS}
MONGO_USER_URI=${MONGO_USER_URI}
MONGO_PASS_URI=${MONGO_PASS_URI}
MONGODB_DB=${MONGODB_DB}
DOMAIN=${DOMAIN}
ADMIN_EMAIL=${ADMIN_EMAIL}
PORT=3000
API_PORT=${API_PORT}
JWT_SECRET=${JWT_SECRET}
TZ=${TIMEZONE}
