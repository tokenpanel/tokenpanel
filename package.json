{
  "name": "tokenpanel",
  "description": "Open-source platform for AI usage tracking, access management, budgets, limits, and an admin dashboard.",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/tokenpanel/tokenpanel.git"
  },
  "homepage": "https://github.com/tokenpanel/tokenpanel#readme",
  "bugs": {
    "url": "https://github.com/tokenpanel/tokenpanel/issues"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && bun run test:manager",
    "test:manager": "for test_file in manager/lib/__tests__/*_test.sh; do bash \"$test_file\" || exit 1; done",
    "e2e": "bash scripts/e2e.sh",
    "config:generate": "bun run packages/config/src/cli.ts generate --root .",
    "config:check": "bun run packages/config/src/cli.ts check-generated --root .",
    "config:policy": "bun run packages/config/src/cli.ts policy --root .",
    "config:diff": "bun run packages/config/src/cli.ts diff --root .",
    "schema:snapshot": "bun run --filter @tokenpanel/db db:schema-snapshot",
    "schema:check": "bun run --filter @tokenpanel/db db:schema-check",
    "release:check": "bun run config:check && bun run config:policy && bun run schema:check",
    "clean": "turbo run clean && rm -rf node_modules",
    "start": "turbo run start",
    "docker:start": "docker compose --profile dev --env-file .env up --build -d --remove-orphans",
    "docker:stop": "docker compose --profile dev --env-file .env stop",
    "docker:restart": "docker compose --profile dev --env-file .env up --build -d --force-recreate --remove-orphans",
    "docker:reset": "docker compose --profile dev --env-file .env down -v --remove-orphans && docker compose --profile dev --env-file .env up --build -d --remove-orphans",
    "docker:logs": "docker compose --profile dev --env-file .env logs -f --tail=100",
    "docker:ps": "docker compose --profile dev --env-file .env ps",
    "docker:prod": "docker compose --profile prod --env-file .env up --build -d --remove-orphans",
    "docker:prod:logs": "docker compose --profile prod --env-file .env logs -f --tail=100",
    "docker:prod:stop": "docker compose --profile prod --env-file .env stop",
    "docker:prod:restart": "docker compose --profile prod --env-file .env up --build -d --force-recreate --remove-orphans"
  },
  "devDependencies": {
    "turbo": "^2.5",
    "typescript": "~6.0.2"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "packageManager": "bun@1.2.21"
}
