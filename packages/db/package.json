{
  "name": "@tokenpanel/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo node_modules/.tmp"
  },
  "dependencies": {
    "mongodb": "^6.18",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}