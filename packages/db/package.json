{
  "name": "@tokenpanel/db",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist .turbo node_modules/.tmp",
    "migrator": "bun run src/migrator/cli.ts",
    "db:new-migration": "bun run src/migrator/cli.ts new",
    "db:migrate": "bun run src/migrator/cli.ts run",
    "db:status": "bun run src/migrator/cli.ts status"
  },
  "dependencies": {
    "mongodb": "^6.18",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
